{
    "workspace.rootPatterns":[".root", ".git"],
    "workspace.ignoredFolders": ["$HOME", "$HOME/.cargo/**", "$HOME/.rustup/**", "**/.git", "**/.clangd"],
    "workspace.ignoredFiletypes": ["bin", "so", "a", "o"],
    "diagnostic.enable":false,
    "diagnostic.level":"warning",
    "diagnostic.signLevel":"warning",
    "diagnostic.enableSign":false,
    "diagnostic.errorSign":"⛔",
    "diagnostic.warningSign":"⚠️",
    "diagnostic.hintSign":"💡",
    "diagnostic.infoSign":"ℹ️",
    "suggest.autoTrigger": "always",
    "suggest.triggerAfterInsertEnter":true,
    "suggest.minTriggerInputLength": 3,
    "suggest.enablePreselect": true,
    "suggest.noselect": true,
    "suggest.labelMaxLength": 100,
    "suggest.removeDuplicateItems":true,
    "inlayHint.enableParameter": false,
    "Lua.diagnostics.disable": ["undefined-global", "lowercase-global"],
    "Lua.diagnostics.globals": ["vim"]
}
